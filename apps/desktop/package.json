{
  "name": "@codestrike/desktop",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/main.js",
  "types": "./src/main.ts",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "electron-is-dev": "^2.0.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "eslint": "^8.56.0",
    "@types/node": "^20.11.0"
  },
  "build": {
    "appId": "ai.codestrike.desktop",
    "productName": "CodeStrike AI",
    "files": [
      "dist/**/*",
      "../web/.next/**/*",
      "../web/next.config.js",
      "../web/package.json",
      "../web/public/**/*"
    ],
    "directories": {
      "buildResources": "assets"
    },
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
