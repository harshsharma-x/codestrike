{
  "name": "codestrike",
  "version": "0.1.2",
  "description": "CodeStrike AI - Open-source AI coding agent CLI",
  "license": "MIT",
  "author": "CodeStrike AI",
  "type": "commonjs",
  "bin": {
    "codestrike": "dist/index.cjs"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/harshsharma-x/codestrike.git"
  },
  "bugs": {
    "url": "https://github.com/harshsharma-x/codestrike/issues"
  },
  "homepage": "https://github.com/harshsharma-x/codestrike#readme",
  "keywords": [
    "ai",
    "coding",
    "cli",
    "code-generation",
    "developer-tools",
    "mcp"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup && node scripts/postbuild.mjs",
    "dev": "tsup --watch",
    "start": "node dist/index.cjs",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.0",
    "inquirer": "^9.2.0",
    "conf": "^12.0.0",
    "zod": "^3.22.0",
    "fast-glob": "^3.3.0"
  },
  "devDependencies": {
    "@codestrike/core": "workspace:*",
    "@codestrike/ai": "workspace:*",
    "@codestrike/agents": "workspace:*",
    "@codestrike/rag": "workspace:*",
    "@codestrike/git": "workspace:*",
    "@codestrike/terminal": "workspace:*",
    "@codestrike/shared": "workspace:*",
    "@codestrike/memory": "workspace:*",
    "@codestrike/mcp": "workspace:*",
    "@codestrike/plugins": "workspace:*",
    "@codestrike/tools": "workspace:*",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0",
    "eslint": "^8.56.0",
    "@types/node": "^20.11.0"
  }
}
