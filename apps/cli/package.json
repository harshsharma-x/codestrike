{
  "name": "codestrike",
  "version": "0.1.0",
  "description": "CodeStrike AI - Open-source AI coding agent CLI",
  "license": "MIT",
  "author": "CodeStrike AI",
  "type": "module",
  "bin": {
    "codestrike": "./dist/index.cjs"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@codestrike/core": "workspace:*",
    "@codestrike/ai": "workspace:*",
    "@codestrike/agents": "workspace:*",
    "@codestrike/rag": "workspace:*",
    "@codestrike/git": "workspace:*",
    "@codestrike/terminal": "workspace:*",
    "@codestrike/shared": "workspace:*",
    "commander": "^12.0.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.0",
    "inquirer": "^9.2.0",
    "conf": "^12.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0",
    "eslint": "^8.56.0",
    "@types/node": "^20.11.0"
  }
}
