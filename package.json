{
  "name": "codestrike",
  "version": "0.1.0",
  "private": true,
  "description": "CodeStrike AI - Open-source AI coding agent",
  "license": "MIT",
  "author": "CodeStrike AI",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md}\"",
    "ci": "turbo lint typecheck test build"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "eslint": "^8.56.0",
    "prettier": "^3.2.0",
    "tsup": "^8.5.1",
    "turbo": "^1.12.0",
    "typescript": "^5.9.3",
    "vitest": "^1.6.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "dependencies": {
    "axios": "^1.18.1",
    "execa": "^9.6.1",
    "fast-glob": "^3.3.3",
    "ignore": "^7.0.6",
    "isomorphic-git": "^1.38.7",
    "zod": "^4.4.3"
  }
}
