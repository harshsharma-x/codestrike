generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String?
  avatarUrl     String?
  passwordHash  String?
  githubId      String?  @unique
  googleId      String?  @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  projects      Project[]
  sessions      Session[]
  configurations Configuration[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model Project {
  id           String         @id @default(cuid())
  name         String
  rootDir      String
  userId       String
  model        String         @default("mistralai/mixtral-8x7b-instruct")
  provider     String         @default("openrouter")
  systemPrompt String?
  temperature  Float?         @default(0.7)
  maxTokens    Int?           @default(4096)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  user         User           @relation(fields: [userId], references: [id])
  conversations Conversation[]
  indexes      Index[]
}

model Conversation {
  id        String    @id @default(cuid())
  title     String    @default("New Conversation")
  projectId String?
  userId    String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  project   Project?  @relation(fields: [projectId], references: [id])
  messages  Message[]
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  role           String
  content        String
  model          String?
  provider       String?
  tokens         Int?
  metadata       Json?
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id])
}

model Index {
  id          String   @id @default(cuid())
  projectId   String
  filePath    String
  content     String
  summary     String
  language    String
  tokens      Int
  embeddings  Json?
  lastIndexed DateTime @default(now())
  project     Project  @relation(fields: [projectId], references: [id])

  @@unique([projectId, filePath])
}

model Configuration {
  id        String   @id @default(cuid())
  userId    String
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
}

model UsageLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  provider  String
  model     String
  tokens    Int?
  duration  Int?
  status    String
  error     String?
  createdAt DateTime @default(now())
}
